# =============================================================================
# .dockerignore — Files excluded from Docker build context
# =============================================================================
# These files are not needed inside the container and excluding them:
#   1. Reduces build context size (faster builds)
#   2. Prevents accidentally overriding container-installed node_modules
#   3. Keeps secrets (.env.local) out of the image layers
# =============================================================================

# Dependencies — installed inside the container via npm ci
node_modules

# Next.js build output — rebuilt inside the container
.next

# Local environment secrets — passed via env_file in docker-compose.yml
.env.local

# Git history — not needed in the container
.git
.gitignore

# IDE and editor config
.vscode
.idea
*.swp
*.swo

# Kiro spec files — development documentation, not needed at runtime
.kiro

# OS files
.DS_Store
Thumbs.db
