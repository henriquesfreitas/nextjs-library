# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env.local and replace the placeholder values with your
# actual credentials. The .env.local file is gitignored and will NOT be
# committed to version control.
#
# Usage:
#   cp .env.example .env.local
#   # Then edit .env.local with your real Neon PostgreSQL connection string
# =============================================================================

# PostgreSQL (Neon) connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
